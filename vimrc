call plug#begin()
Plug 'KKPMW/oldbook-vim'
call plug#end()
set encoding=utf-8
set fileencoding=utf-8
set fileencodings=utf-8
set history=500
set number
filetype plugin on
filetype indent on
set autoread
let mapleader = ","
set so=7
set ruler
set cmdheight=1
set foldcolumn=1
syntax enable
set smarttab
set shiftwidth=2
set tabstop=2
set linebreak
set textwidth=80
set colorcolumn=80
set ai
set si
set laststatus=2
set showmatch
set visualbell
set hlsearch
set smartcase
set ignorecase
set autoindent
set smartindent
colorscheme oldbook
set termguicolors
